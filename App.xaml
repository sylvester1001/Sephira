<?xml version="1.0" encoding="UTF-8" ?>
<Application
    x:Class="Sepat.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Sepat"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Accent Colors -->
            <Color x:Key="AccentColor">#7C4DFF</Color>
            <Color x:Key="AccentColorLight">#B388FF</Color>
            <Color x:Key="AccentColorDark">#651FFF</Color>
            <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
            <SolidColorBrush x:Key="AccentBrushLight" Color="{StaticResource AccentColorLight}" />

            <!-- Status Colors -->
            <Color x:Key="SuccessColor">#4CAF50</Color>
            <Color x:Key="WarningColor">#FF9800</Color>
            <Color x:Key="DangerColor">#F44336</Color>
            <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}" />
            <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}" />
            <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}" />

            <!-- Card Style -->
            <CornerRadius x:Key="CardCornerRadius">8</CornerRadius>
            <Thickness x:Key="CardPadding">24</Thickness>
            <Thickness x:Key="CardMargin">0,0,0,8</Thickness>
            <x:Double x:Key="PageMaxWidth">1000</x:Double>

            <!-- Typography -->
            <x:Double x:Key="PageTitleFontSize">28</x:Double>
            <x:Double x:Key="SectionTitleFontSize">18</x:Double>
            <x:Double x:Key="CardTitleFontSize">16</x:Double>
            <x:Double x:Key="BodyFontSize">14</x:Double>
            <x:Double x:Key="CaptionFontSize">12</x:Double>

            <!-- Card Container Style -->
            <Style x:Key="SettingsCard" TargetType="Border">
                <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
                <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="{StaticResource CardCornerRadius}" />
                <Setter Property="Padding" Value="{StaticResource CardPadding}" />
                <Setter Property="Margin" Value="{StaticResource CardMargin}" />
            </Style>

            <!-- Page Header Style -->
            <Style x:Key="PageTitleStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="{StaticResource PageTitleFontSize}" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Margin" Value="0,0,0,24" />
            </Style>

            <!-- Section Header Style -->
            <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="{StaticResource SectionTitleFontSize}" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Margin" Value="0,16,0,12" />
            </Style>

            <!-- Subtitle Style -->
            <Style x:Key="SubtitleStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="{StaticResource CaptionFontSize}" />
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
