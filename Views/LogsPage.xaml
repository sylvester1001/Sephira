<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="Sepat.Views.LogsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    NavigationCacheMode="Enabled">

    <ScrollViewer Padding="36,24,36,24">
        <StackPanel MaxWidth="{StaticResource PageMaxWidth}" HorizontalAlignment="Stretch">

            <TextBlock Text="运行日志" Style="{StaticResource PageTitleStyle}" />

            <!-- Performance Stats -->
            <Grid ColumnSpacing="12" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource SettingsCard}" Margin="0">
                    <StackPanel Spacing="4">
                        <TextBlock Text="CPU 使用率" Style="{StaticResource SubtitleStyle}" />
                        <TextBlock Text="12%" FontSize="24" FontWeight="Bold" />
                        <ProgressBar Value="12" Maximum="100" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource SettingsCard}" Margin="0">
                    <StackPanel Spacing="4">
                        <TextBlock Text="内存使用" Style="{StaticResource SubtitleStyle}" />
                        <TextBlock Text="156 MB" FontSize="24" FontWeight="Bold" />
                        <ProgressBar Value="15" Maximum="100"
                                     Foreground="{StaticResource AccentBrush}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource SettingsCard}" Margin="0">
                    <StackPanel Spacing="4">
                        <TextBlock Text="识别 FPS" Style="{StaticResource SubtitleStyle}" />
                        <TextBlock Text="30" FontSize="24" FontWeight="Bold" />
                        <ProgressBar Value="100" Maximum="100"
                                     Foreground="{StaticResource SuccessBrush}" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Log Filter -->
            <Border Style="{StaticResource SettingsCard}" Margin="0,0,0,16">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="筛选：" VerticalAlignment="Center" />
                    <ToggleButton Content="全部" IsChecked="True" />
                    <ToggleButton Content="信息" />
                    <ToggleButton Content="警告" />
                    <ToggleButton Content="错误" />
                    <Border Width="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}"
                            Margin="8,4" />
                    <Button Content="清空日志" />
                    <Button Content="导出日志" />
                </StackPanel>
            </Border>

            <!-- Log Entries -->
            <Border Style="{StaticResource SettingsCard}">
                <StackPanel Spacing="4">
                    <!-- Log Entry -->
                    <Grid Padding="8,6" CornerRadius="4"
                          Background="{ThemeResource SubtleFillColorTransparentBrush}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="50" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="18:05:30.123"
                                   FontFamily="Cascadia Code" FontSize="12"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                        <TextBlock Grid.Column="1" Text="INFO"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource AccentBrush}" />
                        <TextBlock Grid.Column="2" Text="系统启动完成，开始挂机"
                                   FontSize="13" />
                    </Grid>

                    <Grid Padding="8,6" CornerRadius="4"
                          Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="50" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="18:05:32.456"
                                   FontFamily="Cascadia Code" FontSize="12"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                        <TextBlock Grid.Column="1" Text="INFO"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource AccentBrush}" />
                        <TextBlock Grid.Column="2" Text="已加载地图：冰封之地"
                                   FontSize="13" />
                    </Grid>

                    <Grid Padding="8,6" CornerRadius="4"
                          Background="{ThemeResource SubtleFillColorTransparentBrush}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="50" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="18:06:01.789"
                                   FontFamily="Cascadia Code" FontSize="12"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                        <TextBlock Grid.Column="1" Text="INFO"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource AccentBrush}" />
                        <TextBlock Grid.Column="2" Text="NPC 识别引擎初始化完成 (OpenCV)"
                                   FontSize="13" />
                    </Grid>

                    <Grid Padding="8,6" CornerRadius="4"
                          Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="50" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="18:08:15.234"
                                   FontFamily="Cascadia Code" FontSize="12"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                        <TextBlock Grid.Column="1" Text="WARN"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource WarningBrush}" />
                        <TextBlock Grid.Column="2" Text="背包空间不足 (32/50)，建议清理"
                                   FontSize="13" />
                    </Grid>

                    <Grid Padding="8,6" CornerRadius="4"
                          Background="{ThemeResource SubtleFillColorTransparentBrush}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="50" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="18:08:16.001"
                                   FontFamily="Cascadia Code" FontSize="12"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                        <TextBlock Grid.Column="1" Text="INFO"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource AccentBrush}" />
                        <TextBlock Grid.Column="2" Text="自动执行交易策略，卖出 12 件白色装备"
                                   FontSize="13" />
                    </Grid>

                    <Grid Padding="8,6" CornerRadius="4"
                          Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="50" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="18:10:45.678"
                                   FontFamily="Cascadia Code" FontSize="12"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                        <TextBlock Grid.Column="1" Text="INFO"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource AccentBrush}" />
                        <TextBlock Grid.Column="2" Text="自动购买 50 瓶 HP 药水（大）"
                                   FontSize="13" />
                    </Grid>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
