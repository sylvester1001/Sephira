<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="Sepat.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    NavigationCacheMode="Enabled">

    <ScrollViewer Padding="36,24,36,24">
        <StackPanel MaxWidth="{StaticResource PageMaxWidth}" HorizontalAlignment="Stretch">

            <!-- Page Title -->
            <TextBlock Text="仪表盘" Style="{StaticResource PageTitleStyle}" />

            <!-- Hero Status Card -->
            <Border Style="{StaticResource SettingsCard}" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Ellipse Width="12" Height="12"
                                     Fill="{StaticResource SuccessBrush}" 
                                     VerticalAlignment="Center" />
                            <TextBlock Text="挂机中" FontSize="20" FontWeight="SemiBold" />
                        </StackPanel>
                        <TextBlock Text="冰封之地 · Lv.30-45"
                                   Style="{StaticResource SubtitleStyle}"
                                   FontSize="14" />
                        <TextBlock Text="已运行 02:34:15"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                   FontSize="13" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8"
                                VerticalAlignment="Center">
                        <Button Content="&#xE769;" FontFamily="Segoe Fluent Icons"
                                Style="{StaticResource AccentButtonStyle}"
                                Width="44" Height="44" Padding="0"
                                ToolTipService.ToolTip="暂停" />
                        <Button Content="&#xE71A;" FontFamily="Segoe Fluent Icons"
                                Width="44" Height="44" Padding="0"
                                ToolTipService.ToolTip="停止" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Stats Row -->
            <TextBlock Text="实时数据" Style="{StaticResource SectionTitleStyle}" />
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Stat Card 1: Kills -->
                <Border Grid.Column="0" Style="{StaticResource SettingsCard}">
                    <StackPanel Spacing="4">
                        <TextBlock Text="击杀数"
                                   Style="{StaticResource SubtitleStyle}" />
                        <TextBlock Text="342" FontSize="28" FontWeight="Bold" />
                        <TextBlock Text="↑ 12/min"
                                   Foreground="{StaticResource SuccessBrush}"
                                   FontSize="12" />
                    </StackPanel>
                </Border>

                <!-- Stat Card 2: Gold -->
                <Border Grid.Column="1" Style="{StaticResource SettingsCard}">
                    <StackPanel Spacing="4">
                        <TextBlock Text="金币"
                                   Style="{StaticResource SubtitleStyle}" />
                        <TextBlock Text="12,450" FontSize="28" FontWeight="Bold" />
                        <TextBlock Text="↑ 520/min"
                                   Foreground="{StaticResource SuccessBrush}"
                                   FontSize="12" />
                    </StackPanel>
                </Border>

                <!-- Stat Card 3: Backpack -->
                <Border Grid.Column="2" Style="{StaticResource SettingsCard}">
                    <StackPanel Spacing="4">
                        <TextBlock Text="背包容量"
                                   Style="{StaticResource SubtitleStyle}" />
                        <TextBlock Text="32/50" FontSize="28" FontWeight="Bold" />
                        <ProgressBar Value="64" Maximum="100" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>

                <!-- Stat Card 4: Potion -->
                <Border Grid.Column="3" Style="{StaticResource SettingsCard}">
                    <StackPanel Spacing="4">
                        <TextBlock Text="药水剩余"
                                   Style="{StaticResource SubtitleStyle}" />
                        <TextBlock Text="85%" FontSize="28" FontWeight="Bold" />
                        <ProgressBar Value="85" Maximum="100" Margin="0,4,0,0"
                                     Foreground="{StaticResource AccentBrush}" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Recent Activity -->
            <TextBlock Text="最近活动" Style="{StaticResource SectionTitleStyle}" />
            <Border Style="{StaticResource SettingsCard}">
                <StackPanel Spacing="12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" Glyph="&#xE73E;"
                                  Foreground="{StaticResource SuccessBrush}"
                                  FontSize="14" Margin="0,0,12,0" />
                        <TextBlock Grid.Column="1" Text="自动购买了 50 瓶红药水" />
                        <TextBlock Grid.Column="2" Text="2 分钟前"
                                   Style="{StaticResource SubtitleStyle}" />
                    </Grid>
                    <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" Glyph="&#xE73E;"
                                  Foreground="{StaticResource SuccessBrush}"
                                  FontSize="14" Margin="0,0,12,0" />
                        <TextBlock Grid.Column="1" Text="卖出了 12 件装备，获得 3,200 金币" />
                        <TextBlock Grid.Column="2" Text="5 分钟前"
                                   Style="{StaticResource SubtitleStyle}" />
                    </Grid>
                    <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" Glyph="&#xE7BA;"
                                  Foreground="{StaticResource WarningBrush}"
                                  FontSize="14" Margin="0,0,12,0" />
                        <TextBlock Grid.Column="1" Text="背包空间不足，建议清理" />
                        <TextBlock Grid.Column="2" Text="15 分钟前"
                                   Style="{StaticResource SubtitleStyle}" />
                    </Grid>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
