<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="Sepat.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    NavigationCacheMode="Enabled">

    <ScrollViewer Padding="36,24,36,24">
        <StackPanel MaxWidth="{StaticResource PageMaxWidth}" HorizontalAlignment="Stretch">

            <TextBlock Text="设置" Style="{StaticResource PageTitleStyle}" />

            <!-- Appearance -->
            <TextBlock Text="外观" Style="{StaticResource SectionTitleStyle}" />

            <Border Style="{StaticResource SettingsCard}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="主题" FontWeight="SemiBold" />
                        <TextBlock Text="选择应用的外观主题"
                                   Style="{StaticResource SubtitleStyle}" />
                    </StackPanel>
                    <ComboBox Grid.Column="1" Width="160" SelectedIndex="0">
                        <ComboBoxItem Content="跟随系统" />
                        <ComboBoxItem Content="浅色" />
                        <ComboBoxItem Content="深色" />
                    </ComboBox>
                </Grid>
            </Border>

            <Border Style="{StaticResource SettingsCard}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="背景材质" FontWeight="SemiBold" />
                        <TextBlock Text="选择窗口背景效果（需要 Windows 11）"
                                   Style="{StaticResource SubtitleStyle}" />
                    </StackPanel>
                    <ComboBox Grid.Column="1" Width="160" SelectedIndex="0">
                        <ComboBoxItem Content="Mica" />
                        <ComboBoxItem Content="Mica Alt" />
                        <ComboBoxItem Content="Acrylic" />
                    </ComboBox>
                </Grid>
            </Border>

            <!-- Python Service -->
            <TextBlock Text="CV 服务" Style="{StaticResource SectionTitleStyle}" />

            <Border Style="{StaticResource SettingsCard}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Python 路径" FontWeight="SemiBold" />
                        <TextBlock Text="指定 Python 解释器路径用于 CV 识别服务"
                                   Style="{StaticResource SubtitleStyle}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                        <TextBox PlaceholderText="python.exe 路径" Width="250" />
                        <Button Content="浏览" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Style="{StaticResource SettingsCard}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="启动时自动连接 CV 服务" FontWeight="SemiBold" />
                        <TextBlock Text="应用启动时自动启动 Python CV 后台服务"
                                   Style="{StaticResource SubtitleStyle}" />
                    </StackPanel>
                    <ToggleSwitch Grid.Column="1" IsOn="True" />
                </Grid>
            </Border>

            <!-- About -->
            <TextBlock Text="关于" Style="{StaticResource SectionTitleStyle}" />
            <Border Style="{StaticResource SettingsCard}">
                <StackPanel Spacing="8">
                    <TextBlock Text="Sepat" FontSize="20" FontWeight="Bold" />
                    <TextBlock Text="版本 0.1.0-dev"
                               Style="{StaticResource SubtitleStyle}" />
                    <TextBlock Text="基于 WinUI 3 + .NET 9 构建的游戏挂机辅助工具"
                               Style="{StaticResource SubtitleStyle}" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
